<Window x:Class="QGo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QGo"
        
        mc:Ignorable="d"
        KeyDown="Window_KeyDown" PreviewKeyDown="Window_PreviewKeyDown" Loaded="MainWindow_Loaded" WindowStyle="ThreeDBorderWindow"
        Title="MainWindow" Height="100" Width="500">
    <Grid>
        <StackPanel>
           
            <TextBox Background="Beige" Height="100" FontSize="24" Name="queryText" TextChanged="queryText_TextChanged">
                <TextBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Name="mnuEditShortcuts" Header="Edit Shortcuts" Click="mnuEditShortcuts_Click" />
                    </ContextMenu>
                </TextBox.ContextMenu>
            </TextBox>
        </StackPanel>
    </Grid>
</Window>
